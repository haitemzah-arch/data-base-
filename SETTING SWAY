default_border none
default_floating_border none
smart_borders off
smart_gaps off
gaps inner 0
gaps outer 0

client.focused          #89b4fa #1e1e2e #cdd6f4 #89b4fa
client.unfocused        #313244 #1e1e2e #6c7086 #313244
client.focused_inactive #313244 #1e1e2e #6c7086 #313244
