# فتح الطرفية
bindsym $mod+Return exec $term

# قائمة التطبيقات
bindsym $mod+d exec $menu

# المتصفح
bindsym $mod+b exec $browser

# مدير الملفات
bindsym $mod+e exec thunar

# إغلاق النافذة
bindsym $mod+q kill

# ملء الشاشة
bindsym $mod+f fullscreen toggle

# تعويم النافذة
bindsym $mod+Shift+f floating toggle

# إعادة تحميل الكونفيغ
