bindsym $mod+v splitev
bindsym $mod+c splitv
bindsym $mod+s layout stacking
bindsym $mod+t layout tabbed
bindsym $mod+w layout toggle split

bindsym $mod+r mode "resize"
mode "resize" {
    bindsym Left  resize shrink width  30px
