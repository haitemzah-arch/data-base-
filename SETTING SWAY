input "type:keyboard" {
    xkb_layout us,ara
    repeat_delay 300
    repeat_rate 50
}

input "type:touchpad" {
    dwt enabled
    tap enabled
    natural_scroll enabled
    middle_emulation enabled
    scroll_method two_finger
