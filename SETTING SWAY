    },

    "sway/window": {
        "max-length": 40
    },

    "clock": {
        "format": "  {:%H:%M}",
        "format-alt": "  {:%Y-%m-%d}",
        "tooltip-format": "{:%A %d %B %Y}"
    },

    "battery": {
